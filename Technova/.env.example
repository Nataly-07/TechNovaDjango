# Entorno: dev | staging | prod
TECHNOVA_ENV=dev

# Django
DJANGO_SECRET_KEY=replace-with-a-long-secret-at-least-32-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos
DB_ENGINE=django.db.backends.postgresql
DB_NAME=DB_TN
DB_USER=postgres
DB_PASSWORD=Admin
DB_HOST=localhost
DB_PORT=5432

# Correo: el .env puede estar en Technova/ (junto a manage.py) o en la raíz del repo Git.
# Depuración sin SMTP (mensaje en la consola del runserver):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
TECHNOVA_PUBLIC_BASE_URL=http://127.0.0.1:8000
# Logo en correos HTML (URL absoluta). Si omites esta línea, se usa TECHNOVA_PUBLIC_BASE_URL + /static/.../logo-technova-email.png
# Para forzar una URL externa (p. ej. CDN): TECHNOVA_EMAIL_LOGO_URL=https://ejemplo.com/logo.png
# 0 = usar solo URL del logo en el HTML (recomendado). 1 = incrustación Base64 si está implementada en el proyecto.
TECHNOVA_EMAIL_LOGO_EMBED_BASE64=0
# 0 = envío sincrónico tras registro (recomendado para ver errores SMTP). 1 = hilo en segundo plano.
TECHNOVA_EMAIL_REGISTRO_ASYNC=0
